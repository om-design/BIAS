+#!/usr/bin/env python3
+"""
+BIAS Protocol - Agent Acquisition Script
+Installs BIAS Protocol to your agent's configuration directory.
+
+Usage:
+    python install.py                    # Interactive mode
+    python install.py --path ~/.agents/  # Specify path
+    python install.py --dry-run          # Preview without installing
+"""
+
+import argparse
+import os
+import sys
+import urllib.request
+from pathlib import Path
+
+
+BIAS_AGENTS_URL = "https://raw.githubusercontent.com/om-design/bias/main/.agents/AGENTS.md"
+
+DEFAULT_PATHS = [
+    Path.home() / ".agents" / "AGENTS.md",
+    Path.home() / ".claude" / "AGENTS.md",
+    Path.cwd() / "AGENTS.md",
+    Path.cwd() / ".agents" / "AGENTS.md",
+]
+
+
+def fetch_bias_protocol() -> str:
+    """Fetch the BIAS Protocol from GitHub."""
+    print(f"Fetching BIAS Protocol from:\n  {BIAS_AGENTS_URL}")
+    try:
+        with urllib.request.urlopen(BIAS_AGENTS_URL, timeout=30) as response:
+            return response.read().decode("utf-8")
+    except Exception as e:
+        print(f"Error fetching protocol: {e}")
+        sys.exit(1)
+
+
+def install_protocol(target_path: Path, content: str, dry_run: bool = False) -> bool:
+    """Install the protocol to target path."""
+    target_path.parent.mkdir(parents=True, exist_ok=True)
+
+    if dry_run:
+        print(f"[DRY RUN] Would write to: {target_path}")
+        print(f"Content length: {len(content)} bytes")
+        return True
+
+    try:
+        target_path.write_text(content, encoding="utf-8")
+        return True
+    except Exception as e:
+        print(f"Error writing file: {e}")
+        return False
+
+
+def interactive_select() -> Path:
+    """Interactive path selection."""
+    print("\nSelect installation target:")
+    paths_with_index = list(enumerate(DEFAULT_PATHS, start=1))
+    for i, path in paths_with_index:
+        marker = " (exists)" if path.exists() else ""
+        print(f"  {i}) {path}{marker}")
+    print(f"  {len(DEFAULT_PATHS) + 1}) Custom path")
+
+    while True:
+        try:
+            choice = int(input("\nEnter choice: "))
+            if 1 <= choice <= len(DEFAULT_PATHS):
+                return DEFAULT_PATHS[choice - 1]
+            elif choice == len(DEFAULT_PATHS) + 1:
+                custom = input("Enter custom path: ").strip()
+                return Path(custom)
+            else:
+                print("Invalid choice. Try again.")
+        except ValueError:
+            print("Please enter a number.")
+        except KeyboardInterrupt:
+            print("\nCancelled.")
+            sys.exit(0)
+
+
+def main():
+    parser = argparse.ArgumentParser(
+        description="Install BIAS Protocol to agent configuration"
+    )
+    parser.add_argument(
+        "--path", "-p",
+        type=Path,
+        help="Target path for AGENTS.md"
+    )
+    parser.add_argument(
+        "--dry-run", "-n",
+        action="store_true",
+        help="Preview without installing"
+    )
+    parser.add_argument(
+        "--quiet", "-q",
+        action="store_true",
+        help="Suppress non-essential output"
+    )
+
+    args = parser.parse_args()
+
+    if not args.quiet:
+        print("=" * 50)
+        print("BIAS Protocol - Agent Acquisition Script")
+        print("=" * 50)
+        print()
+
+    # Fetch protocol
+    content = fetch_bias_protocol()
+
+    # Determine target path
+    if args.path:
+        target = args.path
+        if not target.name.endswith(".md"):
+            target = target / "AGENTS.md"
+    else:
+        # Check for existing installation
+        for existing in DEFAULT_PATHS:
+            if existing.exists():
+                overwrite = input(
+                    f"Found existing AGENTS.md at {existing}. Overwrite? [y/N]: "
+                )
+                if overwrite.lower() == "y":
+                    target = existing
+                    break
+        else:
+            target = interactive_select() if sys.stdin.isatty() else DEFAULT_PATHS[0]
+
+    # Install
+    success = install_protocol(target, content, args.dry_run)
+
+    if success:
+        if not args.quiet:
+            print()
+            print("[OK] BIAS Protocol installed successfully!")
+            print(f"  Location: {target}")
+            print()
+            print("To activate, restart your agent or reference:")
+            print("  https://github.com/om-design/bias/blob/main/.agents/AGENTS.md")
+        return 0
+    else:
+        print("[X] Installation failed.")
+        return 1
+
+
+if __name__ == "__main__":
+    sys.exit(main())
